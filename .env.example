# ============================================================
# ML2 EduManager — environment variables (example)
# Copy this file to `.env` and fill in real values.
# NEVER commit your real `.env` (it is gitignored).
# ============================================================

# --- Public config (exposed to the browser via Vite "VITE_" prefix) ---
# Safe to ship to the client. This is the anon/publishable key, NOT a secret.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# --- Server-side config (SSR / server functions / middleware) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
SUPABASE_PROJECT_ID=your-project-id

# --- Server-ONLY secret ---
# Bypasses Row Level Security. Used by src/integrations/supabase/client.server.ts.
# NEVER prefix this with VITE_ and NEVER expose it to client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
